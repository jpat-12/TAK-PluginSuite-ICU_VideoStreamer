<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet source configuration for WinTAK SDK packages.

  The WinTAK NuGet feed requires a TAK.gov account.
  1. Register at https://tak.gov
  2. Generate an API key in your profile settings
  3. Replace YOUR_API_KEY below (or set credentials via:
       nuget sources add -name WinTAK -source <url> -username <user> -password <key>)

  NOTE: This project does NOT use NuGet for WinTAK DLLs.
  DLLs are referenced directly from libs\ (copied from D:\Apps\).
  This file is kept for reference only.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="WinTAK"    value="https://artifacts.tak.gov/artifactory/api/nuget/WinTAK" />
  </packageSources>
</configuration>
