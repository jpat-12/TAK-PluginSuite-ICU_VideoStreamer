<UserControl x:Class="ICUVideoStreamer.VideoStreamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#FF1E1E1E" Foreground="White">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF3D5F8F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF2D4F7F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 8 0"
                                                      Stroke="#FFAAAAAA" StrokeThickness="1.5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,24,3" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#FF3A3A3A" BorderBrush="#FF555555" BorderThickness="1"/>
                                    <ScrollViewer Margin="0,2">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF2D6A2D"/>
        </Style>
        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF6A2D2D"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <Border Grid.Row="0" Background="#FF2B2B2B" Padding="8,4">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}"
                        Command="{Binding OpenSettingsCommand}" Content="Settings" Width="70"/>
                <Image DockPanel.Dock="Left" Width="40" Height="40" Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Source="pack://application:,,,/ICUVideoStreamer;component/assets/Large.png"/>
                <TextBlock DockPanel.Dock="Left" Text="Video Stream"
                           FontSize="14" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Ellipse DockPanel.Dock="Left" Width="10" Height="10" Margin="0,0,6,0"
                         Fill="{Binding StreamDotColor}" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Left" Text="{Binding BitrateText}"
                           Style="{StaticResource ValueStyle}" Margin="0,0,6,0"/>
                <Border DockPanel.Dock="Left" Background="#FF8B0000" Padding="4,2"
                        CornerRadius="3" Margin="4,0"
                        Visibility="{Binding RecBadgeVisibility}" VerticalAlignment="Center">
                    <TextBlock Text="REC" Foreground="White" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="{Binding StreamElapsedText}" Style="{StaticResource ValueStyle}"
                           Margin="0,0,0,0" DockPanel.Dock="Left"/>
                <TextBlock/>
            </DockPanel>
        </Border>

        <!-- Content Row -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <!-- Camera preview area -->
            <Border Grid.Column="0" Background="#FF111111" Margin="4">
                <Grid>
                    <!-- Live camera feed -->
                    <Image Source="{Binding PreviewBitmap}" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="LowQuality"/>

                    <!-- Placeholder when no feed is active -->
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#FF555555" FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Text" Value="No Camera"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PreviewBitmap}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsScreenShare}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Text" Value="Screen Share Active"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- LIVE badge — top-left, visible only while streaming -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8"
                            Background="#CC1A1A1A" CornerRadius="3" Padding="6,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="● LIVE" Foreground="LimeGreen" FontWeight="Bold" FontSize="11"/>
                    </Border>

                    <!-- REC badge -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,32,0,0"
                            Visibility="{Binding RecBadgeVisibility}">
                        <TextBlock Text="● REC" Foreground="Red" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          Background="#FF3A3A3A"/>

            <!-- Side panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4">

                    <!-- Camera selector -->
                    <TextBlock Text="Camera" Style="{StaticResource LabelStyle}" Margin="0,4,0,2"/>
                    <ComboBox ItemsSource="{Binding CameraDevices}"
                              SelectedValue="{Binding SelectedCamera, Mode=TwoWay}"
                              IsEnabled="{Binding CanChangeSource}"
                              Margin="0,0,0,2" Background="#FF3A3A3A" Foreground="White"/>
                    <CheckBox Content="Screen Share" IsChecked="{Binding IsScreenShare, Mode=TwoWay}"
                              Foreground="White" Margin="0,2,0,4"/>
                    <Button Style="{StaticResource ActionButton}" Content="Refresh Devices"
                            Command="{Binding RefreshDevicesCommand}" Margin="0,0,0,6"/>

                    <!-- Stream URL -->
                    <TextBlock Text="Stream URL" Style="{StaticResource LabelStyle}" Margin="0,4,0,2"/>
                    <TextBox Text="{Binding StreamUrlDisplay, Mode=OneWay}" IsReadOnly="True"
                             Background="#FF2B2B2B" Foreground="#FFAAAAAA"
                             BorderBrush="#FF555555" Padding="4,3" TextWrapping="Wrap"
                             Margin="0,0,0,6"/>

                    <!-- Stream controls -->
                    <Button Style="{StaticResource GreenButton}" Content="Start Stream"
                            Command="{Binding StartStreamCommand}" Margin="0,0,0,2"/>
                    <Button Style="{StaticResource RedButton}" Content="Stop Stream"
                            Command="{Binding StopStreamCommand}" Margin="0,0,0,8"/>

                    <Separator Background="#FF444444" Margin="0,4"/>

                    <!-- GPS Status (WinTAK manages TAK server connection) -->
                    <TextBlock Text="GPS" Style="{StaticResource LabelStyle}" Margin="0,4,0,2"/>
                    <DockPanel Margin="0,0,0,8">
                        <Ellipse Width="8" Height="8" Fill="{Binding GpsDotColor}"
                                 VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                        <TextBlock Text="{Binding GpsStatusText}" Style="{StaticResource ValueStyle}"
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                    <Separator Background="#FF444444" Margin="0,4"/>

                    <!-- Location -->
                    <TextBlock Text="Location" Style="{StaticResource LabelStyle}" Margin="0,4,0,4"/>
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Lat:" Style="{StaticResource LabelStyle}" Margin="0,0,6,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LatText}" Style="{StaticResource ValueStyle}" Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Lon:" Style="{StaticResource LabelStyle}" Margin="0,0,6,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LonText}" Style="{StaticResource ValueStyle}" Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Alt:" Style="{StaticResource LabelStyle}" Margin="0,0,6,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AltText}" Style="{StaticResource ValueStyle}" Margin="0,0,0,2"/>
                    </Grid>

                    <Separator Background="#FF444444" Margin="0,4"/>

                    <!-- ═══ Sensor Heading Indicator ═══ -->
                    <TextBlock Text="Sensor Heading" Style="{StaticResource LabelStyle}" Margin="0,4,0,4"/>

                    <Grid Width="140" Height="140" HorizontalAlignment="Center" Margin="0,2,0,2">

                        <!-- Dashed orbit guide circle -->
                        <Ellipse Width="118" Height="118"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Stroke="#FF404040" StrokeThickness="1"
                                 StrokeDashArray="3,5" Fill="Transparent"/>

                        <!-- Cardinal tick marks -->
                        <Canvas Width="140" Height="140">
                            <Rectangle Canvas.Left="69" Canvas.Top="6"   Width="2" Height="6" Fill="#FF666666"/>
                            <Rectangle Canvas.Left="69" Canvas.Top="128" Width="2" Height="6" Fill="#FF666666"/>
                            <Rectangle Canvas.Left="128" Canvas.Top="69" Width="6" Height="2" Fill="#FF666666"/>
                            <Rectangle Canvas.Left="6"   Canvas.Top="69" Width="6" Height="2" Fill="#FF666666"/>
                            <TextBlock Canvas.Left="64" Canvas.Top="0" Text="N"
                                       Foreground="#FF888888" FontSize="9" FontWeight="Bold"/>
                        </Canvas>

                        <!-- Airplane image — white silhouette, centered, non-rotating -->
                        <Image Width="62" Height="62"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Source="pack://application:,,,/ICUVideoStreamer;component/assets/airplane.png">
                            <!-- Compensate for ~40° natural tilt in the clipart so nose points up (North) -->
                            <Image.RenderTransform>
                                <RotateTransform Angle="-40" CenterX="31" CenterY="31"/>
                            </Image.RenderTransform>
                        </Image>

                        <!-- Rotating arrow — full-canvas container spins around its center -->
                        <Canvas Width="140" Height="140" RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <RotateTransform Angle="{Binding SensorHeading}"/>
                            </Canvas.RenderTransform>
                            <!-- Arrow points up (North) at 0°, orbits clockwise as heading increases -->
                            <Path Canvas.Left="64" Canvas.Top="5"
                                  Data="M6,0 L12,16 L8,13 L8,22 L4,22 L4,13 L0,16 Z"
                                  Fill="#FF00BFFF" Stroke="#FF007ACC" StrokeThickness="0.8"/>
                        </Canvas>
                    </Grid>

                    <!-- Heading readout -->
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4"
                               Style="{StaticResource ValueStyle}"
                               Text="{Binding SensorHeading, StringFormat={}{0:F0}°}"/>

                    <!-- Heading slider 0–360° -->
                    <Slider Minimum="0" Maximum="360"
                            Value="{Binding SensorHeading, Mode=TwoWay}"
                            TickFrequency="45" IsSnapToTickEnabled="False"
                            Margin="0,0,0,6"/>

                    <!-- Elevation label + readout -->
                    <DockPanel Margin="0,2,0,2">
                        <TextBlock DockPanel.Dock="Left" Text="Elevation"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Style="{StaticResource ValueStyle}"
                                   Text="{Binding SensorElevation, StringFormat={}{0:F0}°}"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>

                    <!-- Elevation slider −90° (down) to +90° (up) -->
                    <Slider Minimum="-90" Maximum="90"
                            Value="{Binding SensorElevation, Mode=TwoWay}"
                            TickFrequency="45" IsSnapToTickEnabled="False"
                            Margin="0,0,0,8"/>

                    <Separator Background="#FF444444" Margin="0,4"/>

                    <!-- Manual location entry (expandable) -->
                    <Button Style="{StaticResource ActionButton}" Content="Manual Location ▸"
                            Command="{Binding ToggleManualLocationCommand}" Margin="0,4,0,2"/>
                    <StackPanel Margin="0,0,0,4">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsManualLocationExpanded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Latitude" Style="{StaticResource LabelStyle}" Margin="0,4,0,2"/>
                        <TextBox Text="{Binding ManualLat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#FF2B2B2B" Foreground="White" BorderBrush="#FF555555"
                                 Padding="4,3" Margin="0,0,0,4"/>
                        <TextBlock Text="Longitude" Style="{StaticResource LabelStyle}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding ManualLon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#FF2B2B2B" Foreground="White" BorderBrush="#FF555555"
                                 Padding="4,3" Margin="0,0,0,4"/>
                        <TextBlock Text="Altitude (m)" Style="{StaticResource LabelStyle}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding ManualAlt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#FF2B2B2B" Foreground="White" BorderBrush="#FF555555"
                                 Padding="4,3" Margin="0,0,0,4"/>
                        <Button Style="{StaticResource ActionButton}" Content="Apply Location"
                                Command="{Binding ApplyLocationCommand}"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#FF252525" Padding="8,3">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding BuildDateText}"
                           Style="{StaticResource LabelStyle}" Foreground="#FF666666"
                           FontSize="10" Margin="12,0,0,0"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding ClockText}"
                           Style="{StaticResource LabelStyle}" Margin="8,0,0,0"/>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource LabelStyle}"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
