<Window x:Class="ICUVideoStreamer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Stream Settings" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF1E1E1E" Foreground="White">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="Padding" Value="0,4,8,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 8 0"
                                                      Stroke="#FFAAAAAA" StrokeThickness="1.5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,24,3" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" Margin="4,3,24,3"
                                     VerticalAlignment="Center" Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Style="{x:Null}"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#FF3A3A3A" BorderBrush="#FF555555" BorderThickness="1"/>
                                    <ScrollViewer Margin="0,2">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
        </Style>
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF3D5F8F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF2D4F7F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="8">

            <!-- ========== STREAM TAB ========== -->
            <TabItem Header="Stream">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <Label Content="Protocol"/>
                        <ComboBox x:Name="CboProtocol" SelectionChanged="CboProtocol_SelectionChanged">
                            <ComboBoxItem>RTMP</ComboBoxItem>
                            <ComboBoxItem>RTMPS</ComboBoxItem>
                            <ComboBoxItem>RTSP</ComboBoxItem>
                            <ComboBoxItem>RTSPS</ComboBoxItem>
                            <ComboBoxItem>SRT</ComboBoxItem>
                            <ComboBoxItem>UDP</ComboBoxItem>
                        </ComboBox>
                        <Label Content="Stream URL"/>
                        <TextBox x:Name="TxtStreamUrl"/>
                        <Label Content="Stream Key"/>
                        <TextBox x:Name="TxtStreamKey"/>
                        <Label Content="Username"/>
                        <TextBox x:Name="TxtUsername"/>
                        <Label Content="Password"/>
                        <DockPanel Margin="0,0,0,6">
                            <Button x:Name="BtnShowPassword" DockPanel.Dock="Right" Content="Show"
                                    Width="50" Margin="4,0,0,0" Click="BtnShowPassword_Click"/>
                            <Grid>
                                <PasswordBox x:Name="PwdPassword" Background="#FF2B2B2B" Foreground="White"
                                             BorderBrush="#FF555555" Padding="4,3" Margin="0"/>
                                <TextBox x:Name="TxtPasswordVisible" Background="#FF2B2B2B" Foreground="White"
                                         BorderBrush="#FF555555" Padding="4,3" Margin="0"
                                         Visibility="Collapsed"/>
                            </Grid>
                        </DockPanel>
                        <Label Content="FFmpeg Path (optional — leave blank to use bundled)"/>
                        <DockPanel Margin="0,0,0,6">
                            <Button DockPanel.Dock="Right" Content="Browse..."
                                    Click="BrowseFfmpeg_Click" Width="70"/>
                            <TextBox x:Name="TxtFfmpegPath" DockPanel.Dock="Left"/>
                        </DockPanel>
                        <TextBlock x:Name="TxtFfmpegResolved" Foreground="#FF888888"
                                   FontSize="10" Margin="0,-4,0,6" TextWrapping="Wrap"/>
                        <CheckBox x:Name="ChkUseTls" Content="Use TLS"/>
                        <Label Content="Certificate Path (optional)"/>
                        <DockPanel Margin="0,0,0,6">
                            <Button DockPanel.Dock="Right" Content="Browse..."
                                    Click="BrowseCert_Click" Width="70"/>
                            <TextBox x:Name="TxtCertPath" DockPanel.Dock="Left"/>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========== VIDEO TAB ========== -->
            <TabItem Header="Video">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <Label Content="Codec"/>
                        <ComboBox x:Name="CboVideoCodec">
                            <ComboBoxItem>H264</ComboBoxItem>
                            <ComboBoxItem>H265</ComboBoxItem>
                            <ComboBoxItem>AV1</ComboBoxItem>
                        </ComboBox>
                        <Label Content="Resolution"/>
                        <ComboBox x:Name="CboResolution" IsEditable="True">
                            <ComboBoxItem>1920x1080</ComboBoxItem>
                            <ComboBoxItem>1280x720</ComboBoxItem>
                            <ComboBoxItem>854x480</ComboBoxItem>
                            <ComboBoxItem>640x360</ComboBoxItem>
                        </ComboBox>
                        <Label Content="Frame Rate"/>
                        <ComboBox x:Name="CboFrameRate" IsEditable="True">
                            <ComboBoxItem>60</ComboBoxItem>
                            <ComboBoxItem>30</ComboBoxItem>
                            <ComboBoxItem>25</ComboBoxItem>
                            <ComboBoxItem>15</ComboBoxItem>
                        </ComboBox>
                        <Label Content="Video Bitrate (kbps)"/>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock x:Name="TxtBitrateLabel" DockPanel.Dock="Right"
                                       Foreground="White" Width="60" TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="SldrBitrate" Minimum="200" Maximum="20000"
                                    TickFrequency="200" IsSnapToTickEnabled="True"
                                    ValueChanged="SldrBitrate_ValueChanged"/>
                        </DockPanel>
                        <CheckBox x:Name="ChkEnableRecording" Content="Enable Recording"
                                  Checked="ChkRecording_Changed" Unchecked="ChkRecording_Changed"/>
                        <Label Content="Recording Folder"/>
                        <DockPanel Margin="0,0,0,6">
                            <Button DockPanel.Dock="Right" Content="Browse..."
                                    Click="BrowseRecording_Click" Width="70"/>
                            <TextBox x:Name="TxtRecordingPath" DockPanel.Dock="Left"
                                     IsEnabled="{Binding IsChecked, ElementName=ChkEnableRecording}"/>
                        </DockPanel>
                        <CheckBox x:Name="ChkScreenShare" Content="Enable Screen Share"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========== AUDIO TAB ========== -->
            <TabItem Header="Audio">
                <StackPanel Margin="12">
                    <Label Content="Audio Device"/>
                    <TextBox x:Name="TxtAudioDevice"/>
                    <Label Content="Codec"/>
                    <ComboBox x:Name="CboAudioCodec">
                        <ComboBoxItem>AAC</ComboBoxItem>
                        <ComboBoxItem>OPUS</ComboBoxItem>
                        <ComboBoxItem>G711</ComboBoxItem>
                    </ComboBox>
                    <Label Content="Audio Bitrate (kbps)"/>
                    <ComboBox x:Name="CboAudioBitrate" IsEditable="True">
                        <ComboBoxItem>64</ComboBoxItem>
                        <ComboBoxItem>128</ComboBoxItem>
                        <ComboBoxItem>192</ComboBoxItem>
                        <ComboBoxItem>256</ComboBoxItem>
                    </ComboBox>
                    <CheckBox x:Name="ChkMuteAudio" Content="Mute Audio"/>
                </StackPanel>
            </TabItem>


        </TabControl>

        <!-- Dialog buttons -->
        <Border Grid.Row="1" Background="#FF252525" Padding="8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Cancel" Click="BtnCancel_Click" Width="80"/>
                <Button DockPanel.Dock="Right" Content="Save" Click="BtnSave_Click"
                        Width="80" Background="#FF2D6A2D"/>
                <TextBlock/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
