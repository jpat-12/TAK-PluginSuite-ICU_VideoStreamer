<?xml version="1.0" encoding="utf-8"?>
<!-- ICU VideoStreamer operator pane. Status bar (with the Settings gear top-right,
     UAS-style) over a video preview, with a Broadcast/Flip action bar at the bottom. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:padding="6dp">

    <!-- Status strip: live dot · status · badge · settings gear (top-right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_statusbar"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <View
            android:id="@+id/icu_live_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/live_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/icu_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:text="@string/icu_status_idle" />

        <TextView
            android:id="@+id/icu_dest_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:textColor="#80D8FF"
            android:textSize="12sp"
            android:text="LAN" />

        <ImageButton
            android:id="@+id/icu_settings_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:src="@drawable/ic_settings"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="@string/icu_settings" />
    </LinearLayout>

    <!-- Video preview -->
    <FrameLayout
        android:id="@+id/icu_preview_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="#000000">

        <TextView
            android:id="@+id/icu_preview_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#888888"
            android:text="@string/icu_preview_placeholder" />
    </FrameLayout>

    <!-- Endpoint URLs (shown while live) -->
    <TextView
        android:id="@+id/icu_urls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#B0BEC5"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:maxLines="5"
        android:visibility="gone" />

    <!-- Action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp">

        <Button
            android:id="@+id/icu_broadcast_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/icu_broadcast" />

        <ImageButton
            android:id="@+id/icu_flip_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:padding="10dp"
            android:src="@drawable/ic_flip_camera"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="@string/icu_flip" />
    </LinearLayout>

</LinearLayout>
