<!-- Round quick-bar button. States mirror the UAS video_ui_button family:
     activated = accent, pressed = lighter, default = translucent. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="oval">
            <solid android:color="@color/icu_accent" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/icu_button_pressed" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/icu_button" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
        </shape>
    </item>
</selector>
