<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/icu_bg_input_focused" />
            <corners android:radius="@dimen/icu_radius_input" />
            <stroke android:width="@dimen/icu_border_width" android:color="@color/icu_border_focused" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/icu_bg_input" />
            <corners android:radius="@dimen/icu_radius_input" />
            <stroke android:width="@dimen/icu_border_width" android:color="@color/icu_border" />
        </shape>
    </item>
</selector>
