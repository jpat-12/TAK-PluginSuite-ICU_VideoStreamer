<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/icu_accent_dim" />
            <corners android:radius="@dimen/icu_radius_button" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/icu_accent_pressed" />
            <corners android:radius="@dimen/icu_radius_button" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/icu_accent" />
            <corners android:radius="@dimen/icu_radius_button" />
        </shape>
    </item>
</selector>
